# Database connection for MyNeta API
# Copy this file to .env and update with your actual database credentials

# Format: postgres://username:password@hostname:port/database_name
# Examples:
# For local PostgreSQL: postgres://username@localhost:5432/myneta_db
# For Docker: postgres://postgres:password@db:5432/myneta_db
# For cloud databases: postgres://user:pass@host.rds.amazonaws.com:5432/dbname

DATABASE_URL=postgres://username:password@localhost:5432/myneta_db
